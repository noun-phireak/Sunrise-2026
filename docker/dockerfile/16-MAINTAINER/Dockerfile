FROM alpine:3.20

# MAINTAINER is DEPRECATED. Shown here so students recognise it in old files.
# It still builds, but you'll get a deprecation warning. Use LABEL instead.
MAINTAINER phireaknoun@gmail.com

# The modern replacement:
LABEL maintainer="phireaknoun@gmail.com"

CMD ["echo", "MAINTAINER is deprecated — use LABEL maintainer= instead."]
